<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Estimated_Recurring_Annual_Revenue__c</fullName>
    <description>[CDD NE Wave 1] Added as part of solution to track recurring revenue.  (Estimated Recurring Total Revenue / Contract Length) *12</description>
    <formula>IF(
   NOT(ISBLANK(Contract_Length_CAT__c)),
   Estimated_Recurring_Total_Revenue__c / (Contract_Length_CAT__c /12),
   0)</formula>
    <label>Estimated Recurring Annual Revenue</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
