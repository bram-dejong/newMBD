<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Contribution_This_Year__c</fullName>
    <description>Calculation of the amount of the opportunity realized in the current year based on the close date</description>
    <externalId>false</externalId>
    <formula>IF( Contract_Length_CAT__c &lt; 12, Total_Value_of_the_Deal_CAT__c , Number_of_Days_to_Year_End__c * ( Annual_Average_Value__c / 365))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Contribution This Year</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
